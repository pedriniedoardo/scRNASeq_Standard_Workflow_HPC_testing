rule seurat_analysis:
    '''
    rule to run the seurat analysis.
    '''
    input:
        ######################################################
        # added as last rule, but not needed
        expand(rules.moveCellrangerSummaryMultiRun.output.summary,
                sample_name=SAMPLES_merge.keys()),
        expand(rules.runMultiqc1MultiRun.output.html),
        ######################################################

        rules.integrateSamples.output.rds,
        rules.integrateSamples.output.meta,
        rules.integrateSamples.output.markers,

        # add the annotation routine
        rules.AnnotationCyteTypeR.output.rds,
        
        # --- Conditional Velocity input ---
        expand(rules.runVelocyto.output.loom, sample_name=SAMPLES_merge.keys()) 
        if config.get("run_velocity", False) else []

