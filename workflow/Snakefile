# == pipeline main rules (calling for the outputs) ==
# ======================================================================
#
# rule to create a custom reference with an added transgene
rule cellranger_mkref_default:
    '''
    Wrapper rule to trigger the building of the Cell Ranger reference
    with an added transgene.
    '''
    input:
        rules.cellranger_mkref.output.ref_dir
# --- single run implementation ---

